# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Analytics
EXPO_PUBLIC_AMPLITUDE_API_KEY=your-amplitude-key-here

# RevenueCat
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_your_ios_public_sdk_key
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_your_android_public_sdk_key
EXPO_PUBLIC_REVENUECAT_PREMIUM_ENTITLEMENT_ID=premium
EXPO_PUBLIC_REVENUECAT_OFFERING_ID=default
EXPO_PUBLIC_REVENUECAT_ANNUAL_PRODUCT_ID=nightly_premium_annual
EXPO_PUBLIC_REVENUECAT_MONTHLY_PRODUCT_ID=nightly_premium_monthly

# ElevenLabs (Guided Ritual voice generation + cache warmup)
EXPO_PUBLIC_ELEVENLABS_API_KEY=your-elevenlabs-api-key
EXPO_PUBLIC_ELEVENLABS_VOICE_ID=your-elevenlabs-voice-id
EXPO_PUBLIC_ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# If your ElevenLabs account supports template variables payload, set to true.
# Otherwise the app will replace {NAME1}/{NAME2} locally before synthesis.
EXPO_PUBLIC_ELEVENLABS_USE_VARIABLES_API=false

# DO NOT commit .env — only .env.example
